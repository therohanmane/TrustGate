# ─────────────────────────────────────────────
#  TrustGate — Server Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit the actual .env file to git.
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/trustgate

# JWT — must be at least 32 characters
JWT_SECRET=replace-with-a-very-long-random-string-min-32-chars
JWT_EXPIRE=30d

# AES-256 Master Encryption Key — must be exactly 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=replace-with-64-hex-char-string

# Frontend URL (used in password-reset emails)
CLIENT_URL=http://localhost:5173

# Email (Gmail — use an App Password, not your real password)
EMAIL_USER=yourapp@gmail.com
EMAIL_PASS=your-gmail-app-password
